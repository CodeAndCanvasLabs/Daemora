{
  "name": "daemora",
  "version": "1.0.0-alpha.0",
  "description": "Self-hosted AI agent platform — autonomous, multi-channel, multi-model.",
  "type": "module",
  "license": "AGPL-3.0-or-later",
  "author": "Umar Farooq <umarfarooq0149@gmail.com>",
  "homepage": "https://github.com/CodeAndCanvasLabs/Daemora#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CodeAndCanvasLabs/Daemora.git"
  },
  "bugs": {
    "url": "https://github.com/CodeAndCanvasLabs/Daemora/issues"
  },
  "keywords": [
    "ai-agent",
    "autonomous-agent",
    "mcp",
    "model-context-protocol",
    "llm",
    "openai",
    "anthropic",
    "claude",
    "gpt",
    "gemini",
    "ollama",
    "voice-agent",
    "livekit",
    "cli",
    "self-hosted"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "bin": {
    "daemora": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "ui/dist",
    "crew",
    "skills",
    "public",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "npm run build:voice && tsx watch src/cli/index.ts start",
    "start": "npm run build:voice && tsx src/cli/index.ts start",
    "setup": "tsx src/cli/index.ts setup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist",
    "build": "npm run build:server && npm run build:ui && npm run build:voice",
    "build:server": "tsc -p tsconfig.build.json",
    "build:ui": "cd ui && npm ci && npm run build",
    "build:voice": "esbuild src/voice/VoiceAgent.ts --bundle --platform=node --format=esm --outfile=dist/voice-worker.mjs --packages=external",
    "voice-worker": "node dist/voice-worker.mjs dev",
    "prepublishOnly": "npm run clean && npm run typecheck && npm run build"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.50",
    "@ai-sdk/google": "^3.0.34",
    "@ai-sdk/google-vertex": "^4.0.112",
    "@ai-sdk/openai": "^3.0.37",
    "@clack/prompts": "^1.2.0",
    "@livekit/agents": "^1.2.7",
    "@livekit/agents-plugin-cartesia": "^1.2.7",
    "@livekit/agents-plugin-deepgram": "^1.2.7",
    "@livekit/agents-plugin-elevenlabs": "^1.2.7",
    "@livekit/agents-plugin-livekit": "^1.2.7",
    "@livekit/agents-plugin-openai": "^1.2.7",
    "@livekit/agents-plugin-silero": "^1.2.7",
    "@livekit/rtc-node": "^0.13.25",
    "@types/nodemailer": "^8.0.0",
    "ai": "^6.0.105",
    "better-sqlite3": "^11.8.1",
    "docx": "^9.6.1",
    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "google-auth-library": "^10.6.2",
    "gray-matter": "^4.0.3",
    "imapflow": "^1.3.2",
    "livekit-server-sdk": "^2.15.1",
    "marked": "^18.0.2",
    "nodemailer": "^8.0.5",
    "ollama-ai-provider-v2": "^3.5.0",
    "pdfkit": "^0.18.0",
    "pino": "^10.3.1",
    "pino-pretty": "^11.3.0",
    "pptxgenjs": "^4.0.1",
    "ws": "^8.20.0",
    "yaml": "^2.7.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^4.17.21",
    "@types/marked": "^6.0.0",
    "@types/node": "^22.10.5",
    "@types/pdfkit": "^0.17.6",
    "esbuild": "^0.28.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "@livekit/rtc-node",
      "onnxruntime-node",
      "esbuild",
      "@parcel/watcher",
      "core-js"
    ]
  }
}
