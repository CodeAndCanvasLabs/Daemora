# === AI Model API Keys ===
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
GOOGLE_AI_API_KEY=your-google-ai-key
XAI_API_KEY=xai-your-key
DEEPSEEK_API_KEY=sk-your-deepseek-key
MISTRAL_API_KEY=your-mistral-key
OPENROUTER_API_KEY=sk-or-your-openrouter-key

# === Server ===
PORT=8081

# === Default Model ===
# Latest: openai:gpt-5.2-pro, openai:gpt-5.2, openai:gpt-5-mini (new GPT-5 family)
#         anthropic:claude-opus-4-6, anthropic:claude-sonnet-4-6 (Claude 4 family)
#         google:gemini-3.1-pro-preview, google:gemini-2.5-pro (Gemini 3.x/2.5)
#         xai:grok-4, mistral:mistral-large-2512
# Affordable: openai:gpt-4.1-mini, openai:gpt-5-nano, google:gemini-2.5-flash-lite
# Local (Ollama): ollama:llama4-maverick, ollama:llama3.3
DEFAULT_MODEL=openai:gpt-4.1-mini

# === Channels ===
# NOTE: The HTTP /chat endpoint is disabled (no auth). Use the channels below instead.

# Telegram - create a bot at https://t.me/BotFather
TELEGRAM_BOT_TOKEN=
# Allowlist: comma-separated chat IDs. Empty = open to everyone.
# Find your chat ID by messaging @userinfobot
TELEGRAM_ALLOWLIST=
# Per-channel model override (leave empty to use DEFAULT_MODEL)
TELEGRAM_MODEL=

# WhatsApp + Voice calls - via Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# Voice calls (makeVoiceCall tool) - needs a voice-capable Twilio number
TWILIO_PHONE_FROM=
# Public URL Twilio can reach for interactive call webhooks (ngrok for local dev)
# Example: https://abc123.ngrok.io  or  https://myagent.example.com
VOICE_WEBHOOK_BASE_URL=
# Voice performance tuning (all optional)
VOICE_MODEL=anthropic:claude-haiku-4-5-20251001  # Fastest model for voice (low latency)
VOICE_TTS_VOICE=Polly.Joanna                      # Twilio TTS voice (Polly.Joanna = best quality)
VOICE_TTS_LANGUAGE=en-US
VOICE_SPEECH_TIMEOUT=4                            # Seconds before Twilio starts listening (lower = snappier)
VOICE_POLL_INTERVAL_MS=500                        # How often to check for agent reply while caller holds

# Email - two options (can combine both):
#
# OPTION A: Resend (easiest - just an API key, no SMTP config needed)
#   Sign up free at resend.com → API Keys → Create Key
#   Add your sending domain at resend.com/domains (or use their shared domain for testing)
RESEND_API_KEY=
RESEND_FROM=you@yourdomain.com
#
# OPTION B: Gmail IMAP/SMTP (needed if you want agent to READ your inbox)
#   1. Enable 2FA on Gmail → Google Account → Security → 2-Step Verification
#   2. Create App Password → Google Account → Security → App Passwords → "Mail"
#   3. Paste the 16-char app password below (no spaces)
EMAIL_USER=
EMAIL_PASSWORD=
# Gmail IMAP/SMTP hosts are pre-filled - only change if using another provider:
# EMAIL_IMAP_HOST=imap.gmail.com
# EMAIL_IMAP_PORT=993
# EMAIL_SMTP_HOST=smtp.gmail.com
# EMAIL_SMTP_PORT=587

# Discord - create a bot at https://discord.com/developers/applications
# Enable "Message Content Intent" + invite bot with: Send Messages, Read Message History, Add Reactions
DISCORD_BOT_TOKEN=
# Allowlist: comma-separated Discord user IDs (snowflakes). Empty = open.
DISCORD_ALLOWLIST=
DISCORD_MODEL=

# Slack - create app at https://api.slack.com/apps
# Enable Socket Mode → App-Level Token (xapp-...) as SLACK_APP_TOKEN
# OAuth & Permissions → Bot Token scopes: chat:write, im:history, app_mentions:read, reactions:write
# OAuth & Permissions → Bot Token (xoxb-...) as SLACK_BOT_TOKEN
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
# Allowlist: comma-separated Slack user IDs (Uxxxxxxxx). Empty = open.
SLACK_ALLOWLIST=
SLACK_MODEL=

# LINE - create Messaging API channel at https://developers.line.biz
# Set webhook URL to: https://your-server/webhooks/line
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=
# Allowlist: comma-separated LINE user IDs (Uxxxxxxxx). Empty = open.
LINE_ALLOWLIST=
LINE_MODEL=

# Signal - requires signal-cli running as a REST daemon
# Install: https://github.com/AsamK/signal-cli
# Start daemon: signal-cli -u +1234567890 daemon --http 127.0.0.1:8080
SIGNAL_CLI_URL=
SIGNAL_PHONE_NUMBER=
# Allowlist: comma-separated phone numbers (+1234567890). Empty = open.
SIGNAL_ALLOWLIST=
SIGNAL_MODEL=

# Microsoft Teams - create an Azure Bot at https://portal.azure.com
# Set messaging endpoint to: https://your-server/webhooks/teams
# Under Configuration → copy App ID and create a client secret (App Password)
# Under Channels → Add Microsoft Teams
TEAMS_APP_ID=
TEAMS_APP_PASSWORD=
# Allowlist: comma-separated Teams user IDs or AAD object IDs. Empty = open.
TEAMS_ALLOWLIST=
TEAMS_MODEL=

# Google Chat - create a Chat App at https://console.cloud.google.com
# Enable "Google Chat API" → Configuration → set Bot URL to: https://your-server/webhooks/googlechat
# Create a Service Account (IAM → Service Accounts) → download JSON key
# Paste the entire JSON key contents as one line into GOOGLE_CHAT_SERVICE_ACCOUNT
GOOGLE_CHAT_SERVICE_ACCOUNT=
GOOGLE_CHAT_PROJECT_NUMBER=
# Optional: set PUBLIC_URL so Google request verification works (skipped in dev if unset)
PUBLIC_URL=https://your-server
# Allowlist: comma-separated Google user IDs or emails. Empty = open.
GOOGLE_CHAT_ALLOWLIST=
GOOGLE_CHAT_MODEL=

# WhatsApp allowlist & model override
WHATSAPP_ALLOWLIST=
WHATSAPP_MODEL=

# Email allowlist & model override
EMAIL_ALLOWLIST=
EMAIL_MODEL=

# ── Phase 24 Channels ───────────────────────────────────────────────────────────

# Matrix - create bot account at matrix.org or self-hosted homeserver
# Get access token via: POST /_matrix/client/v3/login
MATRIX_HOMESERVER_URL=
MATRIX_ACCESS_TOKEN=
MATRIX_BOT_USER_ID=

# Mattermost - Bot Account (System Console → Integrations → Bot Accounts)
MATTERMOST_URL=
MATTERMOST_TOKEN=
MATTERMOST_BOT_USER_ID=
MATTERMOST_BOT_USERNAME=

# Twitch chat bot - OAuth token from https://twitchapps.com/tmi/
# Scopes needed: chat:read, chat:edit
TWITCH_BOT_USERNAME=
TWITCH_OAUTH_TOKEN=
TWITCH_CHANNEL=
TWITCH_COMMAND_PREFIX=!ask

# IRC - plain IRC client (no external packages needed)
IRC_SERVER=
IRC_PORT=6667
IRC_NICK=
IRC_CHANNEL=
IRC_PASSWORD=

# iMessage (macOS only) - requires Messages app + Accessibility permissions
# Enable with: IMESSAGE_ENABLED=true (macOS only, uses AppleScript polling)
IMESSAGE_ENABLED=false
IMESSAGE_POLL_INTERVAL_MS=5000
# Allowlist: comma-separated phone numbers or iCloud emails
IMESSAGE_ALLOWLIST=

# Feishu / Lark - create app at https://open.feishu.cn/app
# Set webhook: https://your-server/channels/feishu
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=
FEISHU_PORT=3004

# Zalo Official Account (Vietnam) - https://oa.zalo.me
# Set webhook: https://your-server/channels/zalo
ZALO_APP_ID=
ZALO_APP_SECRET=
ZALO_ACCESS_TOKEN=
ZALO_PORT=3005

# Nextcloud Talk - bot user + app password
# Profile → Security → Devices & Sessions → Create app password
NEXTCLOUD_URL=
NEXTCLOUD_USER=
NEXTCLOUD_PASSWORD=
NEXTCLOUD_ROOM_TOKEN=

# BlueBubbles - iMessage relay server (https://bluebubbles.app)
# Runs on a Mac and exposes an API for iMessages
BLUEBUBBLES_URL=
BLUEBUBBLES_PASSWORD=

# Nostr - decentralized protocol (generate keypair with ssh-keygen or nostr tools)
# Generate: openssl rand -hex 32 (that's your private key)
NOSTR_PRIVATE_KEY=
NOSTR_RELAYS=

# === Phase 24 Tool Config ===

# Google Places API (googlePlaces tool)
GOOGLE_PLACES_API_KEY=

# Google Calendar (calendar tool with provider=google)
GOOGLE_CALENDAR_API_KEY=
GOOGLE_CALENDAR_ID=primary
GOOGLE_CALENDAR_ACCESS_TOKEN=

# Google Contacts (contacts tool with provider=google)
GOOGLE_CONTACTS_ACCESS_TOKEN=

# Philips Hue (philipsHue tool)
# Find bridge IP: philipsHue("discover") or check your router's DHCP leases
# Get API key: curl -X POST http://<bridge-ip>/api -d '{"devicetype":"daemora"}' (press bridge button first)
HUE_BRIDGE_IP=
HUE_API_KEY=

# Sonos (sonos tool)
# Find speaker IP: check your router or use a Sonos app (About section)
SONOS_SPEAKER_IP=

# Ntfy.sh push notifications (notification tool with service=ntfy)
NTFY_URL=https://ntfy.sh
NTFY_TOPIC=
NTFY_TOKEN=

# Pushover push notifications (notification tool with service=pushover)
PUSHOVER_API_TOKEN=
PUSHOVER_USER_KEY=

# Database connections (database tool)
DATABASE_URL=
MYSQL_URL=

# === Text-to-Speech ===
# OpenAI TTS is used by default (requires OPENAI_API_KEY above)
# Optional: ElevenLabs for higher quality / more voices
ELEVENLABS_API_KEY=

# === Meeting STT (Speech-to-Text) ===
# Deepgram: real-time streaming transcription (sub-second latency, speaker diarization)
# Best for live meeting agent. Without it, falls back to batch Whisper (3-second delay).
DEEPGRAM_API_KEY=
# Groq: fast batch transcription (alternative to OpenAI Whisper)
GROQ_API_KEY=

# === Daemon Mode ===
DAEMON_MODE=false
HEARTBEAT_INTERVAL_MINUTES=30

# === Safety ===
PERMISSION_TIER=standard
# Options: minimal (read-only), standard (read+write+sandboxed commands), full (everything)

# === Filesystem Scoping (like Docker volume mounts) ===
# ALLOWED_PATHS - comma-separated list of directories the agent CAN access.
# Leave empty for global access (agent can access any file it has OS permission to read/write).
# Example: ALLOWED_PATHS=/Users/john/Downloads,/Users/john/Projects
ALLOWED_PATHS=

# BLOCKED_PATHS - comma-separated list of directories ALWAYS blocked, even if inside ALLOWED_PATHS.
# Useful for "allow everything except these folders".
# Example: BLOCKED_PATHS=/Users/john/private,/Users/john/secrets
BLOCKED_PATHS=

# RESTRICT_COMMANDS - when true, executeCommand also enforces ALLOWED_PATHS.
# The cwd and any absolute paths in the command string are checked against ALLOWED_PATHS.
# Set to true for maximum isolation. Default false (only file tools are path-checked).
RESTRICT_COMMANDS=false

# === Multi-Tenant Mode ===
# When enabled, each unique user (channel + userId) gets their own tenant record.
# Operator can set per-tenant: model, cost limits, allowed paths, tool allowlist, plan, suspension.
# Storage: data/tenants/tenants.json  |  Workspaces: data/tenants/{id}/workspace/
MULTI_TENANT_ENABLED=false
# AUTO_REGISTER_TENANTS: auto-create tenant records on first message (true by default).
# Set to false to only allow pre-provisioned tenants (manually created via API or CLI).
AUTO_REGISTER_TENANTS=true
# TENANT_ISOLATE_FILESYSTEM: lock each tenant to their own workspace dir by default.
# Overrides global ALLOWED_PATHS for tenants who have no custom allowedPaths configured.
TENANT_ISOLATE_FILESYSTEM=false

# === Sandbox Mode (OS-level command isolation) ===
# "process" (default): commands run in the host process, filesystem tool-level guards apply.
# "docker": commands run inside a Docker container - kernel-level isolation.
#   Requires Docker installed and running. The container gets a volume-mounted workspace.
SANDBOX_MODE=process
# Docker settings (only used when SANDBOX_MODE=docker)
DOCKER_IMAGE=node:22-alpine
DOCKER_MEMORY=512m
DOCKER_CPUS=0.5
# DOCKER_NETWORK: "none" = no internet, "bridge" = outbound internet allowed
DOCKER_NETWORK=none

# === Cost Limits ===
MAX_COST_PER_TASK=0.50
MAX_DAILY_COST=10.00

# === Sub-Agent Model ===
# Default model for ALL sub-agents. Overridden by profile-specific models below.
# Useful to run sub-agents on a cheaper/faster model than the main agent.
# Format: provider:model (e.g. openai:gpt-4.1-mini, anthropic:claude-haiku-4-5, google:gemini-2.0-flash)
SUB_AGENT_MODEL=

# === Task-Type Model Routing (optional - falls back to SUB_AGENT_MODEL → DEFAULT_MODEL) ===
# Set different models for different agent profiles to optimize cost/quality tradeoffs.
# Sub-agents with profile="coder" will use CODE_MODEL, "researcher" uses RESEARCH_MODEL, etc.
CODE_MODEL=
RESEARCH_MODEL=
WRITER_MODEL=
ANALYST_MODEL=

# === Per-Tenant API Key Encryption ===
# Required for production multi-tenant deployments.
# Encrypts per-tenant API keys stored in tenants.json with AES-256-GCM.
# Generate a secure value: openssl rand -hex 32
# WARNING: If not set, an insecure dev fallback is used (visible in daemora doctor output).
DAEMORA_TENANT_KEY=

# === A2A Security (Agent-to-Agent Protocol) ===
# WARNING: A2A allows external agents to send tasks to YOUR agent.
# A rogue agent can try to: read your files, run commands, send emails, drain your API budget.
# Keep DISABLED unless you trust the agents connecting to you.
A2A_ENABLED=false
# Require a secret token for A2A requests (like an API key):
A2A_AUTH_TOKEN=
# Comma-separated allowlist of trusted agent URLs (empty = block all):
A2A_ALLOWED_AGENTS=
# Permission tier for A2A tasks (minimal = read-only, safest):
A2A_PERMISSION_TIER=minimal
# Max cost per A2A task (keep low to prevent cost attacks):
A2A_MAX_COST=0.05
# Max A2A tasks per minute (rate limiting):
A2A_RATE_LIMIT=5
