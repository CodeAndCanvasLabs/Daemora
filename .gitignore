# ── Dependencies ─────────────────────────────────────────────────────────────
node_modules/
pnpm-lock.yaml       # use package-lock.json (npm) or yarn.lock (yarn) instead

# ── Environment - NEVER commit secrets ───────────────────────────────────────
.env
.env.*
!.env.example        # keep the template

# ── Runtime data - generated at runtime, user-specific ───────────────────────
data/
MEMORY.md
HEARTBEAT.md

# ── Skill embedding cache - auto-regenerated on startup ──────────────────────
# (included under data/ above, but listed explicitly for clarity)
# data/skill-embeddings.json

# ── Local-only dirs — never push to GitHub (files kept locally) ──────────────
agents/              # reference agents (OpenClaw, Gemini CLI, Claude Code)
aegis-ui/            # web dashboard (separate repo)
components/          # scratch UI components
daemoreDir/          # scratch directory
docs/                # internal planning docs
PHASES.md            # internal phase planning
DEEP_RESEARCH_REPORT.md
GIT_RULES.md         # local dev notes

# ── Claude Code project context ───────────────────────────────────────────────
.claude/

# ── Test artifacts ────────────────────────────────────────────────────────────
tests/
playwright.config.ts
pnpm-lock.yaml
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/
/playwright/.auth/

# ── Build artifacts ────────────────────────────────────────────────────────────
dist/
build/
*.log

# ── OS & editor ───────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/settings.json
.idea/
*.swp
*.swo
